{
  "name": "@murow/webgpu",
  "version": "0.0.1",
  "description": "WebGPU rendering backend for murow — 2D and 3D instanced renderers",
  "type": "module",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "source": "./src/index.ts",
        "default": "./dist/esm/index.js"
      },
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "npm run build:types && npm run build:js",
    "build:js:type": "esbuild src/index.ts --bundle --platform=browser --packages=external --minify",
    "build:esm": "bun run build:js:type --outdir=dist/esm --format=esm",
    "build:cjs": "bun run build:js:type --outdir=dist/cjs --format=cjs",
    "build:js": "bun run build:esm && bun run build:cjs",
    "build:types": "tsc --emitDeclarationOnly --project tsconfig.json",
    "test": "bun test ./src"
  },
  "keywords": [
    "webgpu",
    "renderer",
    "2d",
    "3d",
    "instancing",
    "game-engine",
    "murow"
  ],
  "author": "Luiz Felipe Moureau",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mococa/murow.git",
    "directory": "packages/webgpu"
  },
  "peerDependencies": {
    "murow": "workspace:*"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "tinyest": "^0.3.1",
    "tinyest-for-wgsl": "^0.3.2",
    "typegpu": "^0.10.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.16",
    "@webgpu/types": "^0.1.69",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}

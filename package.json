{
    "name": "@murow/monorepository",
    "version": "0.0.1",
    "description": "Repository for all murow's packages.",
    "scripts": {
        "build:js": "cd packages/murow && npm run build:js && cd ../webgpu && npm run build:js",
        "test:murow": "cd packages/murow && npm run test",
        "test:webgpu": "cd packages/webgpu && npm run test",
        "pretest": "bun run build:js",
        "test": "concurrently --kill-others-on-fail \"npm run test:murow\" \"npm run test:webgpu\"",
        "build:murow": "cd packages/murow && npm run build:types",
        "build:webgpu": "cd packages/webgpu && npm run build:types",
        "copy-webgpu": "cp -r packages/webgpu/dist packages/murow/dist/webgpu",
        "prebuild": "bun run build:js",
        "build": "npm run build:murow && npm run build:webgpu",
        "postbuild": "npm run copy-webgpu",
        "pub": "npm run test && npm run build && cd packages/murow && npm publish"
    },
    "workspaces": [
        "packages/*",
        "examples/*",
        "benchmarks",
        "benchmarks/*"
    ],
    "author": "Luiz Felipe Moureau",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/moureau-dev/murow.git"
    },
    "bugs": {
        "url": "https://github.com/moureau-dev/murow/issues"
    },
    "type": "module",
    "private": true,
    "devDependencies": {
        "@types/bun": "latest",
        "concurrently": "^9.2.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}

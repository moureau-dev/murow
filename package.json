{
    "name": "@murow/monorepository",
    "version": "0.0.1",
    "description": "Repository for all murow's packages.",
    "scripts": {
        "build:murow": "cd packages/murow && npm run build",
        "build:webgpu": "cd packages/webgpu && npm run build",
        "build": "concurrently \"npm run build:murow\" \"npm run build:webgpu\""
    },
    "workspaces": [
        "packages/*",
        "examples/*",
        "benchmarks",
        "benchmarks/*"
    ],
    "author": "Luiz Felipe Moureau",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/moureau-dev/murow.git"
    },
    "bugs": {
        "url": "https://github.com/moureau-dev/murow/issues"
    },
    "type": "module",
    "private": true,
    "devDependencies": {
        "@types/bun": "latest",
        "concurrently": "^9.2.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
